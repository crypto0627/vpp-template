# ==========================================
# VPP Dashboard - Environment Variables
# ==========================================

# Database (Docker Compose default)
DATABASE_URL="postgresql://vpp_user:vpp_password@localhost:5432/vpp_db"

# JWT Secret (MUST CHANGE IN PRODUCTION!)
JWT_SECRET="your-super-secret-jwt-key-here"

# Mapbox Token (for maps)
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-token-here"

# Anthropic API Key (for AI chat)
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"

# External API (default)
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:3003/data"

# Node Environment
NODE_ENV="development"
